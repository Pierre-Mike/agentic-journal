{
	"name": "agentic-journal",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"deploy": "wrangler deploy",
		"typecheck": "astro check && tsc --noEmit",
		"lint": "biome check --write --no-errors-on-unmatched",
		"lint:ci": "biome check --no-errors-on-unmatched",
		"lint:file": "biome check --write --no-errors-on-unmatched",
		"test": "bun test",
		"e2e": "playwright test",
		"spec:lint": "bun scripts/spec-lint.ts",
		"spec:status": "bun scripts/spec-status.ts",
		"spec:complete": "bun scripts/spec-complete.ts",
		"worktree:open": "bun scripts/worktree-open.ts",
		"worktree:close": "bun scripts/worktree-close.ts",
		"sync": "bun scripts/worktree-close.ts",
		"tasks:verify": "CLAUDE_CODE_ENABLE_TELEMETRY=1 bun scripts/tasks-verify.ts",
		"check": "bun run typecheck && bun run lint && bun run test && bun run spec:lint"
	},
	"dependencies": {
		"@astrojs/cloudflare": "^12.0.0",
		"@astrojs/mdx": "^4.0.0",
		"astro": "^5.0.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.8",
		"@biomejs/biome": "^2.0.0",
		"@cloudflare/workers-types": "^4.20250101.0",
		"@playwright/test": "^1.59.1",
		"@types/bun": "latest",
		"gray-matter": "^4.0.3",
		"lefthook": "^1.11.0",
		"typescript": "^5.7.0",
		"wrangler": "^4.0.0"
	}
}
