{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"types": ["@cloudflare/workers-types", "astro/client", "bun"]
	},
	"include": ["src", "scripts", "tests", "e2e", ".astro", "playwright.config.ts"],
	"exclude": ["dist", "node_modules"]
}
